{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**",
			"!apps/cloud/drizzle/meta",
			"!apps/cloud/worker-configuration.d.ts",
			"!apps/web/public/packbat-mark.svg",
			"!apps/web/src/routeTree.gen.ts"
		]
	},
	"css": {
		"formatter": {
			"quoteStyle": "single"
		},
		"parser": {
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 120
	},
	"linter": {
		"rules": {
			"preset": "recommended",
			"suspicious": {
				"noExplicitAny": "error"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	}
}

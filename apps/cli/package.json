{
	"name": "packbat",
	"version": "0.5.0",
	"description": "Every agent session, kept. Preserves AI-agent sessions as raw, append-only archives in a store you own.",
	"license": "MIT",
	"author": "Liam Vinberg",
	"homepage": "https://packbat.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/liamvinberg/packbat.git"
	},
	"bugs": {
		"url": "https://github.com/liamvinberg/packbat/issues"
	},
	"keywords": [
		"ai-agents",
		"archive",
		"backup",
		"cli"
	],
	"type": "module",
	"engines": {
		"node": ">=22.16"
	},
	"bin": {
		"packbat": "bin/packbat.js"
	},
	"files": [
		"bin",
		"dist",
		"skills",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsx src/main.ts",
		"typecheck": "tsc",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@clack/prompts": "^1.7.0",
		"age-encryption": "^0.3.0",
		"picocolors": "^1.1.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"tsup": "^8.5.1",
		"tsx": "^4.23.0",
		"typescript": "^7.0.2",
		"vitest": "^4.1.10"
	}
}

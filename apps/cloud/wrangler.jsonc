{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "packbat-cloud",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-15",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "packbat-cloud",
			"database_id": "00000000-0000-0000-0000-000000000000",
			"migrations_dir": "drizzle"
		}
	]
}
